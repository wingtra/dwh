# Shared
PROJECT=wingtra-dwh
REGION=europe-west1

# Artifact Registry
DBT_ARTIFACT_REPO=warehouse-pipelines
DBT_IMAGE_NAME=dbt-runner

# Cloud Run Job
DBT_JOB_NAME=dbt-runner
DBT_SA_NAME=dbt-runner
DBT_DATASET=dbt
DBT_SELECTOR=daily
DBT_COMMAND=build
DBT_THREADS=4
DBT_TIMEOUT_SECONDS=300

# Dataset IAM. Comma-separated dataset ids.
DBT_READ_DATASETS=dl_odoo,dl_revolut
DBT_WRITE_DATASETS=cl_odoo,cl_revolut,cl_seeds,il_ops,ol_ops,ol_finance,bl_ops,bl_finance,meta,seeds

# Scheduler
DBT_SCHEDULER_SA_NAME=dbt-scheduler
DBT_SCHEDULE_TIME_ZONE=Europe/Zurich

# Daily scheduler
DBT_DAILY_SCHEDULER_JOB_NAME=dbt-runner-daily
DBT_DAILY_SELECTOR=daily
DBT_DAILY_SCHEDULE=0 6 * * *

# Weekly scheduler. Enable once weekly-tagged dbt resources exist.
DBT_ENABLE_WEEKLY_SCHEDULER=false
DBT_WEEKLY_SCHEDULER_JOB_NAME=dbt-runner-weekly
DBT_WEEKLY_SELECTOR=weekly
DBT_WEEKLY_SCHEDULE=0 7 * * 1
