# Shared
PROJECT=wingtra-dwh
REGION=europe-west1

# Artifact Registry
DBT_ARTIFACT_REPO=warehouse-pipelines
DBT_IMAGE_NAME=dbt-runner

# Cloud Run Job
DBT_JOB_NAME=dbt-runner
DBT_SA_NAME=dbt-runner
DBT_DATASET=dbt
DBT_SELECTOR=weekly
DBT_COMMAND=build
DBT_THREADS=4
DBT_TIMEOUT_SECONDS=300

# Dataset IAM. Comma-separated dataset ids.
DBT_READ_DATASETS=dl_odoo,dl_revolut,seeds,meta,cl_odoo,cl_revolut,cl_seeds,il_ops,ol_ops,ol_finance,bl_ops,bl_finance
DBT_WRITE_DATASETS=seeds,meta,cl_odoo,cl_revolut,cl_seeds,il_ops,ol_ops,ol_finance,bl_ops,bl_finance

# Scheduler
DBT_SCHEDULER_SA_NAME=dbt-scheduler
DBT_SCHEDULE_TIME_ZONE=Europe/Zurich

# Daily scheduler. Runs after the daily Odoo raw load is expected to finish.
DBT_ENABLE_DAILY_SCHEDULER=true
DBT_DAILY_SCHEDULER_JOB_NAME=dbt-runner-daily
DBT_DAILY_SELECTOR=daily
DBT_DAILY_SCHEDULE="30 22 * * *"

# Morning catch-up scheduler. Re-runs the daily selector so data landed by an
# overnight loader retry or manual rerun reaches the modeled layer before the workday.
DBT_ENABLE_MORNING_SCHEDULER=true
DBT_MORNING_SCHEDULER_JOB_NAME=dbt-runner-daily-morning
DBT_MORNING_SCHEDULE="15 6 * * *"

# Weekly scheduler. Revolut is loaded weekly, so current dbt production work is weekly.
DBT_ENABLE_WEEKLY_SCHEDULER=true
DBT_WEEKLY_SCHEDULER_JOB_NAME=dbt-runner-weekly
DBT_WEEKLY_SELECTOR=weekly
DBT_WEEKLY_SCHEDULE="0 7 * * 1"
