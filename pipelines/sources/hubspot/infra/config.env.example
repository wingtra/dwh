# Copy to config.env and fill in values. DO NOT commit config.env.
PROJECT=wingtra-dwh
REGION=europe-west1

HUBSPOT_BQ_DATASET=dl_hubspot
HUBSPOT_BQ_STAGING_DATASET=dl_hubspot_staging
HUBSPOT_RAW_BUCKET=wingtra-dwh-hubspot-raw
HUBSPOT_RAW_PREFIX=hubspot
HUBSPOT_RAW_RETENTION_DAYS=180
HUBSPOT_ARTIFACT_REPO=crm-pipelines

HUBSPOT_RAW_LOADER_JOB_NAME=hubspot-raw-loader
HUBSPOT_RAW_LOADER_SA_NAME=hubspot-raw-loader
HUBSPOT_SCHEDULER_JOB_NAME=hubspot-raw-loader-daily
HUBSPOT_SCHEDULER_SA_NAME=hubspot-scheduler
HUBSPOT_SCHEDULE="30 5 * * *"
HUBSPOT_SCHEDULE_TIME_ZONE=Europe/Zurich

HUBSPOT_SERVICE_KEY_SECRET=hubspot-service-key
HUBSPOT_START_AT=2026-01-01T00:00:00Z
HUBSPOT_LOOKBACK_DAYS=14
HUBSPOT_PAGE_SIZE=200
HUBSPOT_RUN_MODE=incremental
