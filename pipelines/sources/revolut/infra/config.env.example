# Copy to config.env and fill in values. DO NOT commit config.env.
PROJECT=wingtra-dwh
REGION=europe-west1

REVOLUT_BQ_DATASET=dl_revolut
REVOLUT_RAW_BUCKET=wingtra-dwh-revolut-raw
REVOLUT_RAW_PREFIX=revolut
REVOLUT_ARTIFACT_REPO=finance-pipelines

REVOLUT_RAW_LOADER_JOB_NAME=revolut-raw-loader
REVOLUT_RAW_LOADER_SA_NAME=revolut-raw-loader
REVOLUT_SCHEDULER_JOB_NAME=revolut-raw-loader-weekly
REVOLUT_SCHEDULER_SA_NAME=revolut-scheduler
REVOLUT_SCHEDULE=0 5 * * 1
REVOLUT_SCHEDULE_TIME_ZONE=Europe/Zurich

REVOLUT_CLIENT_ID=
REVOLUT_JWT_ISSUER=
REVOLUT_PRIVATE_KEY_SECRET=revolut-business-api-private-key
REVOLUT_REFRESH_TOKEN_SECRET=revolut-business-api-refresh-token
REVOLUT_START_CREATED_AT=2026-01-01T00:00:00Z
REVOLUT_LOOKBACK_DAYS=31
REVOLUT_EXPENSE_START_DATE=2026-01-01T00:00:00Z
# Expenses have no source update timestamp, so retain a full configured history
# window to capture later state, category, and receipt changes.
REVOLUT_EXPENSE_LOOKBACK_DAYS=36500
REVOLUT_PAGE_SIZE=1000
REVOLUT_MAX_PAGES=100
